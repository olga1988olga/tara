#!/bin/bash
set -euxo pipefail

# Ubuntu's unattended-upgrades holds the dpkg lock for a while right after
# boot; wait it out instead of racing it.
while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
  sleep 5
done

# Node.js (required by the Claude Code CLI)
curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
apt-get install -y nodejs

# ffmpeg (required by openai-whisper to decode non-wav audio formats)
apt-get install -y ffmpeg

# Claude Code CLI
npm install -g @anthropic-ai/claude-code

# uv (Python package manager this repo uses)
sudo -u ubuntu bash -c "curl -LsSf https://astral.sh/uv/install.sh | sh"

# Clone TARA into the default user's home dir
sudo -u ubuntu git clone ${tara_repo_url} /home/ubuntu/tara

# Run the web app as a systemd service - starts on boot, restarts on crash,
# keeps running regardless of SSH sessions. Depends on `server/` actually
# being in the git-cloned repo (i.e. committed), so this only takes effect
# once that's pushed - harmless no-op attempt on older commits otherwise.
cat > /etc/systemd/system/tara.service <<'UNITEOF'
[Unit]
Description=TARA web app
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/tara
ExecStartPre=/bin/rm -f /home/ubuntu/tara/uv.lock
ExecStartPre=/home/ubuntu/.local/bin/uv sync
ExecStart=/home/ubuntu/.local/bin/uv run uvicorn server.app:app --host 127.0.0.1 --port 8000
Restart=on-failure

[Install]
WantedBy=multi-user.target
UNITEOF
systemctl daemon-reload
systemctl enable --now tara.service || true

# Caddy - reverse proxies to the app and gets a real Let's Encrypt cert
# automatically, using nip.io (resolves <ip>.nip.io -> that literal IP) so
# no owned domain is needed. Query our own public IP via instance metadata
# since it's different for every instance.
apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' > /etc/apt/sources.list.d/caddy-stable.list
apt update
apt install -y caddy

PUBLIC_IP=$(curl -s http://169.254.169.254/latest/meta-data/public-ipv4)
NIP_DOMAIN="$(echo "$PUBLIC_IP" | tr '.' '-').nip.io"

cat > /etc/caddy/Caddyfile <<CADDYEOF
$NIP_DOMAIN {
    reverse_proxy localhost:8000
}
CADDYEOF
systemctl reload caddy || true
